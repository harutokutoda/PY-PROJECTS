# Random password generator

import random
import string

def generate_password(strength):
    if strength == "simple":
        chars = string.ascii_lowercase
        length = random.randint(8, 10)
    elif strength == "medium":
        chars = string.ascii_letters + string.digits
        length = 12
    elif strength == "strong":
        chars = string.ascii_letters + string.digits + "!@#$%^&*()_+-=[]{}|;:,.<>?"
        length = 16
    return ''.join(random.choice(chars) for _ in range(length))

def main():
    print("=== Password Generator ===")
    print("Choose strength: simple | medium | strong | random")
    demand = input("> ").strip().lower()

    if demand == "random":
        demand = random.choice(["simple", "medium", "strong"])
        print(f"Selected random strength: {demand.upper()}")

    if demand not in ("simple", "medium", "strong"):
        print("Invalid choice.")
        return

    password = generate_password(demand)
    print(f"[{demand.upper()}] Password: {password}")

if __name__ == "__main__":
    main()
